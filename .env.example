# Orgumented Runtime Overrides / Secrets
# Docker defaults live in config/api.docker.json
ORGUMENTED_CONFIG_PATH=config/api.docker.json
PORT=3000

# LLM secrets / optional overrides
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional drift-governance overrides
# META_CONTEXT_PATH=data/meta/context.json
# DRIFT_BUDGET_ENFORCE_ON_REFRESH=true
# DRIFT_BUDGET_OBJECT_NODE_DELTA_MAX=25
# DRIFT_BUDGET_FIELD_NODE_DELTA_MAX=400
# DRIFT_BUDGET_RELATION_DELTA_MAX=1200
# DRIFT_BUDGET_POLICY_NODE_DELTA_MAX=300
# DRIFT_BUDGET_AUTOMATION_NODE_DELTA_MAX=300
# DRIFT_BUDGET_UI_NODE_DELTA_MAX=300
# DRIFT_BUDGET_TOTAL_NODE_DELTA_MAX=1600
# DRIFT_BUDGET_TOTAL_EDGE_DELTA_MAX=6000
# DRIFT_ALLOWLIST_NODE_TYPES=
# DRIFT_ALLOWLIST_RELATIONS=

# Salesforce secrets / org-specific overrides
# SF_AUTH_MODE defaults to cci via config/api.docker.json
# CCI_VERSION=3.78.0
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_REDIRECT_URI=http://localhost/callback
SF_AUTH_CODE_PATH=.secrets/sf-auth-code.txt
SF_TOKEN_STORE_PATH=.secrets/sf-oauth-token.json
