# API
PORT=3000

# SQLite
GRAPH_BACKEND=sqlite
DATABASE_URL=file:./data/orggraph.db

# Metadata source defaults to retrieved org metadata
PERMISSIONS_FIXTURES_PATH=data/sf-project/force-app/main/default
USER_PROFILE_MAP_PATH=data/sf-user-principals.json
EVIDENCE_INDEX_PATH=data/evidence/index.json
REFRESH_STATE_PATH=data/refresh/state.json
REFRESH_AUDIT_PATH=data/refresh/audit.jsonl
ONTOLOGY_REPORT_PATH=data/refresh/ontology-report.json
MIN_CONFIDENCE_DEFAULT=medium
ASK_CONSISTENCY_CHECK_ENABLED=true
ASK_DEFAULT_MODE=deterministic
LLM_ENABLED=false
LLM_PROVIDER=none
LLM_ALLOW_PROVIDER_OVERRIDE=true
LLM_TIMEOUT_MS=12000
LLM_MAX_OUTPUT_TOKENS=400
# OPENAI_API_KEY=...
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
# ANTHROPIC_API_KEY=...
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages
INGEST_UI_METADATA_ENABLED=false
ORGGRAPH_LOG_LEVEL=log,warn,error,debug
ORGGRAPH_HTTP_LOG_ENABLED=true

# Web
NEXT_PUBLIC_API_BASE=http://localhost:3100
ORGGRAPH_WEB_LOG_ENABLED=true

# Salesforce Org Integration (Phase 6)
SF_INTEGRATION_ENABLED=false
SF_AUTH_MODE=oauth_refresh_token
SF_AUTH_URL_PATH=.secrets/sandbox.sfdx-url.txt
SF_ALIAS=orggraph-sandbox
SF_BASE_URL=https://test.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_REDIRECT_URI=http://localhost/callback
SF_AUTH_CODE_PATH=.secrets/sf-auth-code.txt
SF_TOKEN_STORE_PATH=.secrets/sf-oauth-token.json
SF_JWT_KEY_PATH=
SF_USERNAME=
SF_PROJECT_PATH=data/sf-project
SF_MANIFEST_PATH=manifest/package.xml
SF_PARSE_PATH=data/sf-project/force-app/main/default
SF_WAIT_MINUTES=15
SF_RETRY_COUNT=2
SF_RETRY_DELAY_MS=1500
SF_TIMEOUT_SECONDS=900
SF_AUTO_REFRESH_AFTER_RETRIEVE=true
SF_VERBOSE=false
