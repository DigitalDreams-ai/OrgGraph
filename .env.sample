# Orgumented Runtime Overrides / Secrets
# Optional JSON override file. Leave unset for the default local desktop runtime.
# ORGUMENTED_CONFIG_PATH=config/api.local.json
PORT=3000

# LLM secrets / optional overrides
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# ASK_LLM_MAX_LATENCY_MS=12000
# ASK_LLM_COST_BUDGET_USD=0.02

# Optional drift-governance overrides
# META_CONTEXT_PATH=data/meta/context.json
# ORGUMENTED_PROJECT_MEMORY_PATH=data/project-memory/events.jsonl
# ORGUMENTED_PROJECT_MEMORY_WORKSPACE_ROOT=C:\Users\sean\Projects\GitHub\OrgGraph
# DRIFT_BUDGET_ENFORCE_ON_REFRESH=true
# DRIFT_BUDGET_OBJECT_NODE_DELTA_MAX=25
# DRIFT_BUDGET_FIELD_NODE_DELTA_MAX=400
# DRIFT_BUDGET_RELATION_DELTA_MAX=1200
# DRIFT_BUDGET_POLICY_NODE_DELTA_MAX=300
# DRIFT_BUDGET_AUTOMATION_NODE_DELTA_MAX=300
# DRIFT_BUDGET_UI_NODE_DELTA_MAX=300
# DRIFT_BUDGET_TOTAL_NODE_DELTA_MAX=1600
# DRIFT_BUDGET_TOTAL_EDGE_DELTA_MAX=6000
# DRIFT_ALLOWLIST_NODE_TYPES=
# DRIFT_ALLOWLIST_RELATIONS=


# Salesforce org overrides (auth uses Salesforce CLI keychain only)
# Authenticate inside runtime with:
# sf org login web --alias <alias> --instance-url <url> --set-default
SF_ALIAS=orgumented-sandbox
SF_BASE_URL=https://test.salesforce.com
# Optional selector override for `npm run sf:retrieve` (comma-separated `Type` or `Type:Member`)
# SF_RETRIEVE_SELECTORS=CustomObject:Account,Flow,PermissionSet
# Optional runtime pin override (defaults to 4.5.0)
# CCI_VERSION_PIN=4.5.0
