{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orgumented",
  "version": "0.1.0",
  "identifier": "com.orgumented.desktop",
  "build": {
    "beforeDevCommand": "node ./scripts/dev-runtime.mjs",
    "devUrl": "http://127.0.0.1:3001",
    "beforeBuildCommand": "node ./scripts/prepare-packaged-runtime.mjs",
    "frontendDist": "./runtime/web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Orgumented",
        "width": 1440,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "runtime/api",
      "runtime/config.json",
      "runtime/node/node.exe",
      "runtime/manifest.json"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
