{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @orggraph/ontology build && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "lint": "echo 'lint not configured yet'",
    "test": "pnpm test:validation && pnpm test:parser && pnpm test:integration",
    "test:integration": "pnpm --filter @orggraph/ontology build && ts-node --transpile-only test/integration.ts",
    "test:parser": "pnpm --filter @orggraph/ontology build && ts-node --transpile-only test/parser-errors.ts && ts-node --transpile-only test/apex-class-parser.ts && ts-node --transpile-only test/flow-parser.ts && ts-node --transpile-only test/planner.ts && ts-node --transpile-only test/evidence-store.ts && ts-node --transpile-only test/org-service.ts",
    "test:validation": "pnpm --filter @orggraph/ontology build && ts-node --transpile-only test/validation.ts",
    "typecheck": "pnpm --filter @orggraph/ontology build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@orggraph/ontology": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "better-sqlite3": "^11.8.1",
    "fast-xml-parser": "^4.5.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.17.19",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  }
}
