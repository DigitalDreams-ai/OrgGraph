{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm exec next dev",
    "prebuild": "node ../../scripts/clean-eadir.mjs",
    "build": "pnpm exec next build",
    "start": "pnpm exec next start",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:runtime-status": "pnpm exec ts-node --project tsconfig.test.json --transpile-only test/runtime-status-surfaces.ts",
    "test:proof-history": "pnpm exec ts-node --project tsconfig.test.json --transpile-only test/proof-history-selection.ts"
  },
  "dependencies": {
    "next": "14.2.15",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.16.9",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "typescript": "5.6.3"
  }
}
